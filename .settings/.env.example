# MiMo TUI Backend Configuration
# Copy this file to .env and fill in your values

# Required: Your API key for the OpenAI-compatible service
OPENAI_API_KEY=sk-your-api-key-here

# Optional: API base URL (default: https://api.openai.com/v1)
# For Chinese providers, examples:
#   https://api.deepseek.com/v1
#   https://api.moonshot.cn/v1
#   https://dashscope.aliyuncs.com/compatible-mode/v1
OPENAI_BASE_URL=https://api.openai.com/v1

# Optional: Model name (default: gpt-3.5-turbo)
MODEL_NAME=gpt-3.5-turbo

# Optional: System prompt for the LLM
# SYSTEM_PROMPT=你是 MiMo，一个由小米开发的智能助手。你善于思考，乐于助人，回答简洁准确。

# Optional: WebSocket server settings
# WS_HOST=0.0.0.0
# WS_PORT=8765
