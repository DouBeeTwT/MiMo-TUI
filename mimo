#!/usr/bin/env bash
# MiMo TUI — single entry point
# Sets up Python venv (if needed), starts backend, waits until ready,
# then launches the TUI. Everything is cleaned up on exit.

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
TUI_DIR="$SCRIPT_DIR/TUI"
BACKEND_DIR="$SCRIPT_DIR/Scripts"
SETTINGS_DIR="$SCRIPT_DIR/.settings"
VENV_DIR="$SCRIPT_DIR/.venv"
PYTHON="$VENV_DIR/bin/python"
PIP="$VENV_DIR/bin/pip"
SERVER_LOG=$(mktemp)

# ── Cleanup on exit ─────────────────────────────────────────────────────
cleanup() {
  if [[ -n "${PYTHON_PID:-}" ]]; then
    kill "$PYTHON_PID" 2>/dev/null || true
    wait "$PYTHON_PID" 2>/dev/null || true
  fi
  rm -f "$SERVER_LOG"
}
trap cleanup EXIT INT TERM

# ── Setup Python virtual environment ────────────────────────────────────
if [[ ! -d "$VENV_DIR" ]]; then
  echo "Creating Python virtual environment..."
  python3 -m venv "$VENV_DIR"
  echo "Installing dependencies..."
  "$PIP" install -q -r "$BACKEND_DIR/requirements.txt"
  echo "Python environment ready."
else
  "$PIP" install -q -r "$BACKEND_DIR/requirements.txt" 2>/dev/null || true
fi

# ── Auto-create .env from example if missing ────────────────────────────
if [[ ! -f "$SETTINGS_DIR/.env" && -f "$SETTINGS_DIR/.env.example" ]]; then
  cp "$SETTINGS_DIR/.env.example" "$SETTINGS_DIR/.env"
  echo "  Created .settings/.env from .env.example — edit it with your API key"
fi

# ── Start Python backend (silent, log to file) ──────────────────────────
"$PYTHON" "$BACKEND_DIR/server.py" >"$SERVER_LOG" 2>&1 &
PYTHON_PID=$!

# ── Wait for WebSocket server to be ready ───────────────────────────────
for i in $(seq 1 30); do
  if curl -s -o /dev/null http://localhost:8765/docs 2>/dev/null; then
    break
  fi
  if ! kill -0 "$PYTHON_PID" 2>/dev/null; then
    echo "Backend failed to start:"
    cat "$SERVER_LOG"
    exit 1
  fi
  sleep 0.3
done

# ── Launch TUI (foreground, not exec — so cleanup trap fires) ───────────
cd "$TUI_DIR"
bun run index.ts
